{
  "expo": {
    "name": "PeiPei",
    "slug": "peipei",
    "version": "1.0.0",
    "orientation": "default",
    "icon": "./assets/icon.png",
    "scheme": "peipei",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0F0E0C"
    },
    "ios": {
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "PeiPei uses the camera so you can attach workout photos to your coach chat.",
        "NSMicrophoneUsageDescription": "PeiPei uses the microphone so you can record voice messages for your coach.",
        "NSPhotoLibraryAddUsageDescription": "PeiPei saves coach cards and shared images to your photo library when you ask.",
        "NSPhotoLibraryUsageDescription": "PeiPei uses your photo library so you can attach images to your coach chat."
      },
      "bundleIdentifier": "com.peipei.app",
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0F0E0C",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-widgets",
        {
          "enablePushNotifications": true,
          "groupIdentifier": "group.com.peipei.app",
          "widgets": [
            {
              "name": "PeiPeiQuickView",
              "displayName": "PeiPei Quick View",
              "description": "Today's workout, race countdown, and the latest coach note.",
              "supportedFamilies": [
                "accessoryInline",
                "accessoryRectangular"
              ]
            }
          ]
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#8B3A3A"
        }
      ],
      "expo-secure-store",
      "expo-font",
      "expo-sharing",
      "expo-audio"
    ],
    "extra": {
      "router": {},
      "eas": {
        "build": {
          "experimental": {
            "ios": {
              "appExtensions": [
                {
                  "targetName": "ExpoWidgetsTarget",
                  "bundleIdentifier": "com.peipei.app.ExpoWidgetsTarget",
                  "entitlements": {
                    "com.apple.security.application-groups": [
                      "group.com.peipei.app"
                    ]
                  }
                }
              ]
            }
          }
        },
        "projectId": "bc1270fa-4266-4ae4-97d6-02077d3f9e2b"
      }
    },
    "owner": "ldxstc"
  }
}
