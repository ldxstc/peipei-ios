{
  "expo": {
    "name": "PeiPei",
    "slug": "peipei",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "peipei",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0F0E0C"
    },
    "ios": {
      "bundleIdentifier": "com.peipei.app",
      "supportsTablet": false
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-widgets",
        {
          "enablePushNotifications": true,
          "groupIdentifier": "group.com.peipei.app",
          "widgets": [
            {
              "name": "PeiPeiQuickView",
              "displayName": "PeiPei Quick View",
              "description": "Today's workout, race countdown, and the latest coach note.",
              "supportedFamilies": [
                "accessoryInline",
                "accessoryRectangular"
              ]
            }
          ]
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#8B3A3A"
        }
      ],
      "expo-secure-store",
      "expo-font",
      "expo-widgets"
    ]
  }
}
